<Window x:Class="StorageScanner.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:views="clr-namespace:StorageScanner.Views"
        mc:Ignorable="d"
        Title="Storage Cleaner v1.0.0" Height="780" Width="1380"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}"
        FontFamily="{StaticResource UiFont}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- TOOLBAR -->
        <Border Grid.Row="0" Background="White"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Margin="12,8">

                <TextBlock Text="Location" VerticalAlignment="Center"
                           Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" Margin="0,0,8,0"/>
                <ComboBox ItemsSource="{Binding AvailableDrives}"
                          SelectedItem="{Binding SelectedDrive}" Width="240"/>
                <Button Style="{StaticResource GhostButton}" Command="{Binding BrowseFolderCommand}"
                        Margin="6,0,0,0" Padding="10,0" ToolTip="Browse folder">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock FontFamily="{StaticResource IconFont}" Text="&#xE8DA;" FontSize="13" Margin="0,0,6,0"/>
                        <TextBlock Text="Browse"/>
                    </StackPanel>
                </Button>

                <Separator Width="1" Background="{StaticResource BorderBrush}" Margin="12,4"/>

                <Button Style="{StaticResource PrimaryButton}" Command="{Binding ScanCommand}"
                        Margin="0,0,6,0" ToolTip="Scan selected location">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock FontFamily="{StaticResource IconFont}" Text="&#xE773;" FontSize="13" Margin="0,0,6,0"/>
                        <TextBlock Text="Scan"/>
                    </StackPanel>
                </Button>

                <Button Style="{StaticResource DangerButton}" Command="{Binding CancelCommand}"
                        Margin="0,0,12,0" ToolTip="Cancel current operation">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock FontFamily="{StaticResource IconFont}" Text="&#xE711;" FontSize="13" Margin="0,0,6,0"/>
                        <TextBlock Text="Cancel"/>
                    </StackPanel>
                </Button>

                <Button Style="{StaticResource GhostButton}" Command="{Binding ScanCleanupCommand}"
                        Margin="0,0,12,0" ToolTip="Find cleanup candidates in selected location">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock FontFamily="{StaticResource IconFont}" Text="&#xEF35;" FontSize="13" Margin="0,0,6,0"/>
                        <TextBlock Text="Scan Cleanup"/>
                    </StackPanel>
                </Button>

                <Separator Width="1" Background="{StaticResource BorderBrush}" Margin="0,4,12,4"/>

                <Button Style="{StaticResource GhostButton}" Command="{Binding ExportCsvCommand}"
                        Margin="0,0,6,0" ToolTip="Export scan results to CSV">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock FontFamily="{StaticResource IconFont}" Text="&#xE898;" FontSize="13" Margin="0,0,6,0"/>
                        <TextBlock Text="CSV"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource GhostButton}" Command="{Binding ExportJsonCommand}"
                        ToolTip="Export scan results to JSON">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock FontFamily="{StaticResource IconFont}" Text="&#xE898;" FontSize="13" Margin="0,0,6,0"/>
                        <TextBlock Text="JSON"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>

        <!-- PROGRESS BAR (scan) -->
        <ProgressBar Grid.Row="1" Height="3"
                     Value="{Binding ScanProgressValue}" Maximum="100"
                     IsIndeterminate="{Binding IsScanning}"
                     Background="Transparent"
                     Foreground="{StaticResource AccentBrush}"
                     BorderThickness="0"/>

        <!-- TABS -->
        <TabControl Grid.Row="2">

            <!-- ── Tree Explorer ── -->
            <TabItem Header="Tree Explorer">
                <!--
                    CanUserSortColumns=False: clicking column headers on a flat-tree
                    ObservableCollection destroys parent-child order. Tree is pre-sorted
                    by TotalSize desc at each expand level.
                -->
                <DataGrid Style="{StaticResource ModernDataGrid}"
                          ItemsSource="{Binding TreeItems}"
                          CanUserSortColumns="False">
                    <DataGrid.Columns>

                        <DataGridTemplateColumn Header="Name" Width="360" CanUserResize="True" CanUserSort="False">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="{Binding Indent}">
                                        <Button Background="Transparent" BorderThickness="0" Padding="2,0"
                                                Width="18" Cursor="Hand"
                                                Command="{Binding DataContext.ToggleExpandCommand,
                                                          RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}"
                                                Visibility="{Binding HasChildren, Converter={StaticResource BoolToVisConverter}}">
                                            <TextBlock FontFamily="{StaticResource IconFont}"
                                                       Text="{Binding ExpandIcon}"
                                                       FontSize="10" Foreground="#666"
                                                       VerticalAlignment="Center"/>
                                        </Button>
                                        <Border Width="18"
                                                Visibility="{Binding HasChildren, Converter={StaticResource BoolToHiddenConverter}}"/>
                                        <TextBlock FontFamily="{StaticResource IconFont}"
                                                   Text="{Binding FileIcon}"
                                                   FontSize="13" Margin="0,0,5,0"
                                                   Foreground="#555" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding Name}" FontSize="12"
                                                   TextTrimming="CharacterEllipsis"
                                                   VerticalAlignment="Center" MaxWidth="250"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- SortMemberPath points to raw numeric so sort works correctly -->
                        <DataGridTextColumn Header="Size"      Binding="{Binding SizeFormatted}"     Width="90"  SortMemberPath="Node.TotalSize"      ElementStyle="{StaticResource RightAlignStyle}" CanUserSort="False"/>
                        <DataGridTextColumn Header="%"         Binding="{Binding Percent}"            Width="58"  SortMemberPath="Node.PercentOfParent" ElementStyle="{StaticResource RightAlignStyle}" CanUserSort="False"/>
                        <DataGridTextColumn Header="Allocated" Binding="{Binding AllocatedFormatted}" Width="90"  SortMemberPath="Node.TotalAllocated"  ElementStyle="{StaticResource RightAlignStyle}" CanUserSort="False"/>
                        <DataGridTextColumn Header="Items"     Binding="{Binding ItemCount}"          Width="60"  ElementStyle="{StaticResource RightAlignStyle}" CanUserSort="False"/>
                        <DataGridTextColumn Header="Files"     Binding="{Binding FileCount}"          Width="58"  ElementStyle="{StaticResource RightAlignStyle}" CanUserSort="False"/>
                        <DataGridTextColumn Header="Folders"   Binding="{Binding FolderCount}"        Width="62"  ElementStyle="{StaticResource RightAlignStyle}" CanUserSort="False"/>
                        <DataGridTextColumn Header="Category"  Binding="{Binding Category}"           Width="*"   CanUserSort="False"/>
                    </DataGrid.Columns>

                    <DataGrid.ContextMenu>
                        <ContextMenu FontFamily="{StaticResource UiFont}">
                            <MenuItem Header="Open in Explorer"
                                      Command="{Binding DataContext.OpenInExplorerCommand,
                                                RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      CommandParameter="{Binding Node}"/>
                            <MenuItem Header="Send to Recycle Bin"
                                      Command="{Binding DataContext.DeleteFileCommand,
                                                RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      CommandParameter="{Binding Node}"/>
                        </ContextMenu>
                    </DataGrid.ContextMenu>
                </DataGrid>
            </TabItem>

            <!-- ── Top 100 Largest ── -->
            <TabItem Header="Top 100 Largest">
                <DataGrid Style="{StaticResource ModernDataGrid}"
                          ItemsSource="{Binding TopLargestItems}"
                          CanUserSortColumns="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Name"       Binding="{Binding Name}"     Width="220"/>
                        <DataGridTextColumn Header="Path"       Binding="{Binding FullPath}" Width="*"/>
                        <DataGridTextColumn Header="Size"
                                            Binding="{Binding Size, Converter={StaticResource SizeConverter}}"
                                            SortMemberPath="Size"
                                            Width="90" ElementStyle="{StaticResource RightAlignStyle}"/>
                        <DataGridTextColumn Header="Allocated"
                                            Binding="{Binding AllocatedSize, Converter={StaticResource SizeConverter}}"
                                            SortMemberPath="AllocatedSize"
                                            Width="90" ElementStyle="{StaticResource RightAlignStyle}"/>
                        <DataGridTextColumn Header="%"
                                            Binding="{Binding PercentOfParent, StringFormat='{}{0:F1}%'}"
                                            SortMemberPath="PercentOfParent"
                                            Width="58" ElementStyle="{StaticResource RightAlignStyle}"/>
                        <DataGridTextColumn Header="Category"   Binding="{Binding Category}"    Width="110"/>
                        <DataGridTextColumn Header="Compressed" Binding="{Binding IsCompressed}" Width="85"/>
                    </DataGrid.Columns>
                    <DataGrid.ContextMenu>
                        <ContextMenu FontFamily="{StaticResource UiFont}">
                            <MenuItem Header="Open in Explorer"
                                      Command="{Binding DataContext.OpenInExplorerCommand,
                                                RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      CommandParameter="{Binding}"/>
                            <MenuItem Header="Send to Recycle Bin"
                                      Command="{Binding DataContext.DeleteFileCommand,
                                                RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      CommandParameter="{Binding}"/>
                        </ContextMenu>
                    </DataGrid.ContextMenu>
                </DataGrid>
            </TabItem>

            <!-- ── Treemap ── -->
            <TabItem Header="Treemap">
                <views:TreemapControl RootNode="{Binding ScanResult}"/>
            </TabItem>

            <!-- ── By Type ── -->
            <TabItem Header="By Type">
                <DataGrid Style="{StaticResource ModernDataGrid}"
                          ItemsSource="{Binding FileTypeStats}"
                          CanUserSortColumns="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Extension"  Binding="{Binding Type}"      Width="160"/>
                        <DataGridTextColumn Header="Total Size"
                                            Binding="{Binding TotalSize, Converter={StaticResource SizeConverter}}"
                                            SortMemberPath="TotalSize"
                                            Width="120" ElementStyle="{StaticResource RightAlignStyle}"/>
                        <DataGridTextColumn Header="Files"      Binding="{Binding FileCount}" SortMemberPath="FileCount" Width="100" ElementStyle="{StaticResource RightAlignStyle}"/>
                        <DataGridTextColumn Header="%"          Binding="{Binding Percentage, StringFormat=N2}" SortMemberPath="Percentage" Width="80" ElementStyle="{StaticResource RightAlignStyle}"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <!-- ── By Category ── -->
            <TabItem Header="By Category">
                <DataGrid Style="{StaticResource ModernDataGrid}"
                          ItemsSource="{Binding CategoryStats}"
                          CanUserSortColumns="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Category"   Binding="{Binding Category}"  Width="180"/>
                        <DataGridTextColumn Header="Total Size"
                                            Binding="{Binding SizeFormatted}"
                                            SortMemberPath="TotalSize"
                                            Width="120" ElementStyle="{StaticResource RightAlignStyle}"/>
                        <DataGridTextColumn Header="Files"      Binding="{Binding FileCount}" SortMemberPath="FileCount" Width="100" ElementStyle="{StaticResource RightAlignStyle}"/>
                        <DataGridTextColumn Header="%"          Binding="{Binding Percentage, StringFormat=N2}" SortMemberPath="Percentage" Width="80" ElementStyle="{StaticResource RightAlignStyle}"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <!-- ── Cleanup ── -->
            <TabItem Header="Cleanup">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>   <!-- cleanup progress bar -->
                        <RowDefinition Height="*" MinHeight="200"/>
                        <RowDefinition Height="5"/>      <!-- splitter -->
                        <RowDefinition Height="200"/>    <!-- detail panel -->
                    </Grid.RowDefinitions>

                    <!-- Cleanup loading indicator -->
                    <ProgressBar Grid.Row="0" Height="3"
                                 IsIndeterminate="True"
                                 Foreground="{StaticResource AccentBrush}"
                                 Background="Transparent" BorderThickness="0"
                                 Visibility="{Binding IsCleanupScanning, Converter={StaticResource BoolToVisConverter}}"/>

                    <!-- Cleanup list -->
                    <DataGrid Grid.Row="1" Style="{StaticResource ModernDataGrid}"
                              ItemsSource="{Binding CleanupItems}"
                              SelectedItem="{Binding SelectedCleanupItem, Mode=TwoWay}"
                              CanUserSortColumns="True">
                        <DataGrid.Columns>
                            <!-- Safety badge -->
                            <DataGridTemplateColumn Header="Safety" Width="90" CanUserSort="True" SortMemberPath="Safety">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="3" Padding="6,2" HorizontalAlignment="Left" Margin="4,2">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Safety}" Value="Safe">
                                                            <Setter Property="Background" Value="#E6F4EA"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Safety}" Value="Review">
                                                            <Setter Property="Background" Value="#FFF8E1"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Safety}" Value="Caution">
                                                            <Setter Property="Background" Value="#FDEEEE"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding SafetyLabel}" FontSize="11" FontWeight="SemiBold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Safety}" Value="Safe">
                                                                <Setter Property="Foreground" Value="#1E7E34"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Safety}" Value="Review">
                                                                <Setter Property="Foreground" Value="#856404"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Safety}" Value="Caution">
                                                                <Setter Property="Foreground" Value="#C42B1C"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTextColumn Header="Category"    Binding="{Binding Category}"       Width="110"/>
                            <DataGridTextColumn Header="Name"        Binding="{Binding Name}"           Width="160"/>
                            <DataGridTextColumn Header="Size"
                                                Binding="{Binding SizeLabel}"
                                                SortMemberPath="Size"
                                                Width="90" ElementStyle="{StaticResource RightAlignStyle}"/>
                            <DataGridTextColumn Header="Files"
                                                Binding="{Binding FileCountLabel}"
                                                SortMemberPath="FileCount"
                                                Width="80" ElementStyle="{StaticResource RightAlignStyle}"/>
                            <DataGridTextColumn Header="Description" Binding="{Binding Description}"    Width="*"/>
                        </DataGrid.Columns>
                        <DataGrid.ContextMenu>
                            <ContextMenu FontFamily="{StaticResource UiFont}">
                                <MenuItem Header="Delete permanently"
                                          Command="{Binding DataContext.DeleteCleanupItemCommand,
                                                    RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                          CommandParameter="{Binding}"/>
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                    </DataGrid>

                    <!-- Splitter -->
                    <GridSplitter Grid.Row="2" Height="5" HorizontalAlignment="Stretch"
                                  Background="#EBEBEB" ResizeDirection="Rows"/>

                    <!-- Detail panel: all files inside selected cleanup item -->
                    <Grid Grid.Row="3" Background="White">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Background="#F7F7F7"
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                                Padding="12,6">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock FontFamily="{StaticResource IconFont}" Text="&#xE946;"
                                           FontSize="13" Foreground="{StaticResource AccentBrush}" Margin="0,0,8,0"/>
                                <TextBlock FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"
                                           Foreground="{StaticResource TextSecondaryBrush}">
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat="Files inside: {0}">
                                            <Binding Path="SelectedCleanupItem.Name" FallbackValue="(select an item above)"/>
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                                <TextBlock Text="{Binding SelectedCleanupItem.FileCountLabel, StringFormat=' — {0}'}"
                                           FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                                           VerticalAlignment="Center" Margin="4,0,0,0"/>
                                <Button Style="{StaticResource DangerButton}" Margin="16,0,0,0" Height="24" FontSize="11"
                                        Command="{Binding DeleteCleanupItemCommand}"
                                        CommandParameter="{Binding SelectedCleanupItem}"
                                        Padding="10,0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock FontFamily="{StaticResource IconFont}" Text="&#xE74D;" FontSize="11" Margin="0,0,5,0"/>
                                        <TextBlock Text="Delete Selected"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Border>

                        <DataGrid Grid.Row="1" Style="{StaticResource ModernDataGrid}"
                                  ItemsSource="{Binding CleanupFileDetails}"
                                  RowHeight="22" CanUserSortColumns="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="File Name" Binding="{Binding Name}"         Width="280"/>
                                <DataGridTextColumn Header="Size"
                                                    Binding="{Binding SizeFormatted}"
                                                    SortMemberPath="Size"
                                                    Width="100" ElementStyle="{StaticResource RightAlignStyle}"/>
                                <DataGridTextColumn Header="Full Path" Binding="{Binding Path}"         Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Grid>
            </TabItem>

        </TabControl>

        <!-- TOAST NOTIFICATION (floats bottom-right of tab area) -->
        <Border Grid.Row="2" Panel.ZIndex="99"
                VerticalAlignment="Bottom" HorizontalAlignment="Right"
                Margin="0,0,16,12"
                CornerRadius="6" Padding="14,10"
                MaxWidth="480" MinWidth="260"
                Visibility="{Binding NotifVisible, Converter={StaticResource BoolToVisConverter}}">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Background" Value="#1A1A1A"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding NotifState}" Value="Running">
                            <Setter Property="Background" Value="#1565C0"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding NotifState}" Value="Success">
                            <Setter Property="Background" Value="#1B5E20"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding NotifState}" Value="Error">
                            <Setter Property="Background" Value="#B71C1C"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding NotifState}" Value="Warning">
                            <Setter Property="Background" Value="#E65100"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <StackPanel Orientation="Horizontal">
                <!-- State icon -->
                <TextBlock FontFamily="{StaticResource IconFont}"
                           Text="{Binding NotifIcon}"
                           FontSize="14" Foreground="White"
                           VerticalAlignment="Center" Margin="0,0,10,0"/>
                <!-- Message -->
                <TextBlock Text="{Binding NotifMessage}"
                           FontFamily="{StaticResource UiFont}"
                           FontSize="12" Foreground="White"
                           VerticalAlignment="Center"
                           TextWrapping="Wrap" MaxWidth="380"/>
            </StackPanel>
        </Border>

        <!-- STATUS BAR -->
        <Border Grid.Row="3" Background="White"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0"
                Padding="12,5">
            <StackPanel Orientation="Horizontal">
                <TextBlock FontFamily="{StaticResource IconFont}" Text="&#xE946;"
                           FontSize="11" Foreground="{StaticResource AccentBrush}" Margin="0,0,6,0"
                           VerticalAlignment="Center"/>
                <TextBlock Text="{Binding StatusText}" FontSize="11"
                           Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                <Separator Width="1" Background="{StaticResource BorderBrush}" Margin="12,2"/>
                <TextBlock Text="{Binding CleanupStatus}" FontSize="11"
                           Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
